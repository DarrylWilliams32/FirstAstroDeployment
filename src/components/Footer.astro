---
const platform = "codeberg"
const username = "ryuujisan32"


---

<footer>

    <link rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.1/css/all.min.css'>
    <script src="https://kit.fontawesome.com/cb78e564c1.js" crossorigin="anonymous"></script>
  
    <p>Learn more about my projects on <a href={`https://www.${platform}.com/${username}`}>{platform}</a> or the following platforms:</p>

    <div class="wrapper">
            <a href="https://www.linkedin.com/in/darryl-williams-ii/" class="icon linkedin">
              <div class="tooltip">Linkedin</div>
              <span><i class="fa-brands fa-linkedin"></i></span>
            </a>
            <a href="https://twitter.com/thedeewilliams" class="icon twitter">
              <div class="tooltip">Twitter</div>
              <span><i class="fab fa-twitter"></i></span>
            </a>
            <a href="https://www.instagram.com/theofficialdarrylwilliams/" class="icon instagram">
              <div class="tooltip">Instagram</div>
              <span><i class="fab fa-instagram"></i></span>
            </a>
            <a href="https://github.com/DarrylWilliams32" class="icon github">
              <div class="tooltip">Github</div>
              <span><i class="fab fa-github"></i></span>
            </a>
            <a href="https://www.youtube.com/channel/UCCsZ2j-iSlK7p3LEJLWNQ7w" class="icon youtube">
              <div class="tooltip">Youtube</div>
              <span><i class="fab fa-youtube"></i></span>
            </a>
          </div>
</footer>

<style>
    .foot {
    margin-bottom: 0;
 }

 .wrapper{
    & .icon {
        position: relative;
        background-color: var(--main-color);
        border-radius: 50%;
        margin: 10px;
        width: 50px;
        height: 50px;
        line-height: 50px;
        font-size: 22px;
        display: inline-block;
        align-items: center;
        box-shadow: 0 10px 10px rgba(255, 255, 255, 0.1);
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        color: #333;
        text-decoration: none;
        &:hover {
          & .tooltip {
            top: -45px;
            opacity: 1;
            visibility: visible;
            pointer-events: auto;
          }
          & span,
          & .tooltip {
            text-shadow: 0px -1px 0px rgba(0, 0, 0, 0.1);
          }
        }
    }
    & .tooltip {
        position: absolute;
        top: 0;
        line-height: 1.5;
        font-size: 14px;
        background-color: #ffffff;
        color: #ffffff;
        padding: 5px 8px;
        border-radius: 5px;
        box-shadow: 0 10px 10px rgba(0, 0, 0, 0.1);
        opacity: 0;
        pointer-events: none;
        transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        &::before {
            position: absolute;
            content: "";
            height: 8px;
            width: 8px;
            background-color: #ffffff;
            bottom: -3px;
            left: 50%;
            transform: translate(-50%) rotate(45deg);
            transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        }
    }
    & .linkedin:hover,& .linkedin:hover .tooltip,& .linkedin:hover .tooltip::before {
        background-color: #3b5999;
        color: #ffffff;
    }
    & .twitter:hover,& .twitter:hover .tooltip,& .twitter:hover .tooltip::before {
        background-color: #46c1f6;
        color: #ffffff;
    }
    & .instagram:hover,& .instagram:hover .tooltip,& .instagram:hover .tooltip::before {
        background-color: #e1306c;
        color: #ffffff;
    }
    & .github:hover,& .github:hover .tooltip,& .github:hover .tooltip::before {
        background-color: #333333;
        color: #ffffff;
    }
    & .youtube:hover,& .youtube:hover .tooltip,& .youtube:hover .tooltip::before {
        background-color: #de463b;
        color: #ffffff;
    }
}
</style>